# Normalize line endings across platforms.
# Techne is host-agnostic (Claude Code / Hermes / OpenCode on any OS); keep LF
# in the repo AND on checkout so Windows doesn't churn the diff with CRLF.
* text=auto eol=lf

# Common binaries — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
